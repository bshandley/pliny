# -------------------------------------------------------
# Pliny — required settings
# -------------------------------------------------------

# The public URL your Pliny instance is served from (no trailing slash)
PLINY_URL=https://pliny.example.com

# Port to expose on the host (default: 80)
PLINY_PORT=80

# Strong random string — used to sign JWTs. Change this.
# Generate one: openssl rand -hex 32
JWT_SECRET=change-me-use-openssl-rand-hex-32

# Strong database password. Change this.
DB_PASSWORD=change-me-strong-password

# -------------------------------------------------------
# Optional — TOTP two-factor authentication
# -------------------------------------------------------
# Required if you enable 2FA for any users.
# Generate one: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=

# -------------------------------------------------------
# Optional — Email / SMTP (for notifications + password reset)
# -------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# -------------------------------------------------------
# Optional — S3-compatible file storage (for attachments)
# Default: local disk inside the container
# -------------------------------------------------------
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
