# Required
DB_PASSWORD=change-me-strong-password
JWT_SECRET=change-me-long-random-string
PLINY_URL=http://localhost:8080

# Initial admin account (created on first boot if no users exist)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=changeme

# Optional — port to expose the client on (default: 8080)
# PLINY_PORT=8080

# Optional — database (defaults work for docker-compose)
# DB_HOST=db
# DB_PORT=5432
# DB_NAME=pliny
# DB_USER=pliny

# Optional — SMTP for email notifications
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=yourpassword
# SMTP_FROM=pliny@example.com

# Optional — S3-compatible storage (uses local disk by default)
# S3_ENDPOINT=https://s3.example.com
# S3_BUCKET=pliny
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key

# Optional — OIDC / SSO
# OIDC_ISSUER=https://auth.example.com
# OIDC_CLIENT_ID=pliny
# OIDC_CLIENT_SECRET=your-client-secret

# Optional — TOTP encryption key (generate with: openssl rand -hex 32)
# TOTP_ENCRYPTION_KEY=
